# ── База данных ────────────────────────────────────────────────────────────
# Локальная разработка (npm run dev): Postgres на localhost.
DATABASE_URL="postgresql://subtrack:subtrack@localhost:5432/subtrack?schema=public"

# ── Auth.js (Блок 2) ───────────────────────────────────────────────────────
# Секрет сессий: openssl rand -base64 32
AUTH_SECRET="change-me-openssl-rand-base64-32"
# Google OAuth (console.cloud.google.com → Credentials → OAuth client)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Базовый URL приложения (для колбэков OAuth)
NEXTAUTH_URL="http://localhost:3000"

# ── Начальные администраторы ───────────────────────────────────────────────
# Список email через запятую — сидятся в whitelist с ролью admin при старте.
ADMIN_EMAILS="admin@example.com"

# ── Прочее ─────────────────────────────────────────────────────────────────
# Таймзона для cron и отображения дат (по умолчанию Europe/Kyiv).
APP_TZ="Europe/Kyiv"
# Базовая валюта отчётов (дублируется в настройках инстанса).
BASE_CURRENCY="USD"
